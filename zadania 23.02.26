-- 2
SELECT bilety.nr_biletu
FROM bilety
WHERE bitely.nr_przejazdy = 504
ORDER BY bilety.ilosc DESC;

-- 3
SELECT DISTINKT skład.lokomtywa
FROM skład
;

-- 4
SELECT bilety.nr_przyjazdu, SUM(bilety.cena * bilety.ilosc - bielety.cena * bilety.ilosc * bilety.ulga)
FROM bilety
GROUP BY bilrty.nr_przejazdy
ORDER BY SUM(bilety.cena * bilety.ilosc - bielety.cena * bilety.ilosc * bilety.ulga)
LIMIT 1;

-- 5
SELECT SUM(bilety.ilosc) 
FROM przejadzy
JOIN bilety ON 
GROUP BY stacja_poczatkowa DESC
LIMIT 1

