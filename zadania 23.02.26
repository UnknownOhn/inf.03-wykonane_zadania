select distinct kursy.magazyn_koncowy
from kursy
join magazyn on kursy.magazyn_poczantkowy = magazyny.nazwa
where magazyny.nazwa LIKE "%Torun%";


SELECT DISTINCT pojazdy.model
FROM pojazdy
WHERE pojadzy.ladownosc <= 3,5;

SELECT kursy.magazyn_poczatkowy, kursy.magazyn_koncowy, COUNT(kursy.lp), SUM(kursy.data_koncowa - data_poczatkowa)
FROM kursy
GROUP BY kursy.magazyn_poczatkowy, kursy.magazyn_koncowy
ORDER BY count(LP) DESC, magazyn ASC;


